PORT=4000
NODE_ENV=development

# Ganti sesuai koneksi PostgreSQL lo (lokal atau Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/wms_db?schema=public"

# Ganti dengan random string panjang, jangan pakai contoh ini di production
JWT_ACCESS_SECRET="ganti-dengan-random-string-panjang-untuk-access-token"
JWT_REFRESH_SECRET="ganti-dengan-random-string-panjang-berbeda-untuk-refresh-token"

# Origin frontend, buat CORS
CORS_ORIGIN="http://localhost:5173"
